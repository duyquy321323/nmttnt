# API
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Database (MySQL)
# Dùng MySQL có sẵn trên máy (port 3306):
DATABASE_URL=mysql+pymysql://root:321323@localhost:3306/edu_chatbot?charset=utf8mb4
# Hoặc MySQL trong Docker (port 3307): docker compose --profile mysql up -d
# DATABASE_URL=mysql+pymysql://edu:edu123@localhost:3307/edu_chatbot?charset=utf8mb4

# Auth
JWT_SECRET_KEY=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Default accounts
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=Admin@123
TEACHER_DEFAULT_PASSWORD=Teacher@123
STUDENT_DEFAULT_PASSWORD=Student@123

# Frontend URL (link chia sẻ session)
FRONTEND_URL=http://localhost:3001

# Document storage
DOCUMENTS_STORAGE_PATH=./storage/documents

# Gemini (lấy key tại https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_THINKING_BUDGET=0

# Qdrant RAG
# Local (Docker): docker compose up -d qdrant
QDRANT_URL=http://localhost:6333
# Qdrant Cloud — dùng URL KHÔNG có :6333 (shared hosting chỉ mở port 443)
# QDRANT_URL=https://xxxxxxxx.aws.cloud.qdrant.io
# QDRANT_API_KEY=your-qdrant-cloud-api-key
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=edu_documents
QDRANT_TIMEOUT=120
RAG_INGEST_BATCH_SIZE=32
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=80
RAG_FETCH_K=20
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.45
RAG_MIN_LEXICAL_SCORE=0.25
RAG_MIN_VECTOR_SCORE=0.32
RAG_MIN_RERANK_SCORE=0.35
